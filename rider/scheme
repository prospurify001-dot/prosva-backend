const mongoose = require("mongoose");

const rideSchema = new mongoose.Schema(
  {
    rider: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "User"
    },
    driver: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "Driver",
      default: null
    },
    pickupLocation: {
      lat: Number,
      lng: Number
    },
    dropoffLocation: {
      lat: Number,
      lng: Number
    },
    status: {
  type: String,
  enum: ["pending", "accepted", "picked_up", "completed"],
  default: "pending"
}
  },
  { timestamps: true }
);

module.exports = mongoose.model("Ride", rideSchema);